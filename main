local function addHitLog(msg)
	if not S.hitlogs then return end
	local l=Instance.new("TextLabel",hitLogHolder) l.Size=UDim2.new(1,0,0,20)
	l.BackgroundColor3=C("hudBg") l.BackgroundTransparency=0.25 l.BorderSizePixel=0
	l.Text="  "..msg l.TextColor3=C("hudText") l.TextSize=11 l.Font=Enum.Font.Gotham
	l.TextXAlignment=Enum.TextXAlignment.Left l.ZIndex=161
	Instance.new("UICorner",l).CornerRadius=UDim.new(0,4)
	TS:Create(l,TweenInfo.new(3.5),{TextTransparency=1,BackgroundTransparency=1}):Play()
	task.delay(3.7,function() if l.Parent then l:Destroy() end end)
end

-- ============================================================
-- SAFE ZONE ESP
-- ============================================================
local szBoxes={}
local function updateSZesp()
	for _,b in pairs(szBoxes) do pcall(function() b:Destroy() end) end szBoxes={}
	if not S.safeZoneESP then return end
	for _,zn in ipairs(SAFE_ZONES) do
		local z=workspace:FindFirstChild(zn,true)
		if z and z:IsA("BasePart") then
			local box=Instance.new("SelectionBox",workspace)
			box.Adornee=z box.Color3=Color3.fromRGB(0,200,255) box.LineThickness=0.04 box.SurfaceTransparency=0.8
			szBoxes[zn]=box
		end
	end
end

-- ============================================================
-- BULLET CHAMS
-- ============================================================
local bulletConn=nil
local function startBulletChams()
	if bulletConn then return end
	for _,p in ipairs(workspace:GetDescendants()) do
		if p.Name=="tracer" and p:IsA("BasePart") then
			p.Color=S.bulletColor p.Material=S.bulletMat p.Transparency=S.bulletAlpha
		end
	end
	bulletConn=workspace.DescendantAdded:Connect(function(p)
		if p.Name=="tracer" and p:IsA("BasePart") then
			p.Color=S.bulletColor p.Material=S.bulletMat p.Transparency=S.bulletAlpha
		end
	end)
end
local function stopBulletChams()
	if bulletConn then bulletConn:Disconnect() bulletConn=nil end
end

-- ============================================================
-- AURA & TRAIL
-- ============================================================
local auraAngle=0
local function createAura(char)
	if not char then return end
	local ex=char:FindFirstChild("PtichkaAura") if ex then ex:Destroy() end
	local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
	local af=Instance.new("Model",char) af.Name="PtichkaAura"
	local a0=Instance.new("Attachment",hrp) a0.Name="AuraCenter"
	local n=8
	for i=1,n do
		local p=Instance.new("Part",af) p.Size=Vector3.new(0.1,0.1,0.1)
		p.CanCollide=false p.Anchored=false p.Transparency=1 p.CastShadow=false
		local weld=Instance.new("Weld",p) weld.Part0=hrp weld.Part1=p
		local ang=((i/n)*math.pi*2)
		weld.C0=CFrame.new(math.cos(ang)*2.5,(i%3-1)*2,math.sin(ang)*2.5)
		local a1=Instance.new("Attachment",p)
		local beam=Instance.new("Beam",af)
		beam.Attachment0=a0 beam.Attachment1=a1 beam.Width0=0.06 beam.Width1=0.06
		beam.Color=ColorSequence.new(S.auraColor) beam.LightEmission=1 beam.LightInfluence=0
		beam.FaceCamera=true
		beam.Transparency=NumberSequence.new({
			NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(0.5,0),NumberSequenceKeypoint.new(1,0.3)
		})
	end
end
local function createTrail(char)
	local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
	if hrp:FindFirstChild("PtichkaTrail") then return end
	local a0=Instance.new("Attachment",hrp) a0.Position=Vector3.new(0,1,0) a0.Name="TrailA0"
	local a1=Instance.new("Attachment",hrp) a1.Position=Vector3.new(0,-1,0) a1.Name="TrailA1"
	local t=Instance.new("Trail",hrp) t.Name="PtichkaTrail"
	t.Attachment0=a0 t.Attachment1=a1 t.Lifetime=0.4 t.MinLength=0
	t.FaceCamera=true t.LightEmission=1
	t.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,S.motionTrailColor),ColorSequenceKeypoint.new(1,S.motionTrailColor)})
	t.Transparency=NumberSequence.new({ColorSequenceKeypoint.new(0,0.2),ColorSequenceKeypoint.new(1,1)})
	t.WidthScale=NumberSequence.new({ColorSequenceKeypoint.new(0,1),ColorSequenceKeypoint.new(1,0)})
end

-- ============================================================
-- MAIN LOOPS
-- ============================================================
local lastCamCF=cam.CFrame
local trigLastFire=0
local trigLastCheck=0
local wm_fps,wm_fc,wm_lf=0,0,0
local wm_ping,wm_lp=0,0

-- HEARTBEAT: No Recoil + Sprint + Trample + FPS/Ping
RS.Heartbeat:Connect(function()
	wm_fc=wm_fc+1
	local now=tick()
	if now-wm_lf>=1 then wm_fps=math.floor(wm_fc/(now-wm_lf)) wm_fc=0 wm_lf=now end
	if now-wm_lp>=1 then
		pcall(function() wm_ping=math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) end)
		wm_lp=now
	end

	-- NO RECOIL (точная копия образца)
	NR_UpdateCurrentGun()
	if S.NR_CurrentGun and S.NR_CurrentGunConfig then
		local cfg=S.NR_CurrentGunConfig
		local name=S.NR_CurrentGun.Name
		if S.noRecoil then
			if not S.NR_OrigRecoil[name] then
				S.NR_OrigRecoil[name]={RecoilX=cfg.RecoilX or 0,RecoilY=cfg.RecoilY or 0}
			end
			local factor=1-(S.recoilPct/100)
			cfg.RecoilX=S.NR_OrigRecoil[name].RecoilX*factor
			cfg.RecoilY=S.NR_OrigRecoil[name].RecoilY*factor
		else
			local o=S.NR_OrigRecoil[name]
			if o then cfg.RecoilX=o.RecoilX cfg.RecoilY=o.RecoilY end
		end
	end

	-- AUTO SPRINT
	if S.autoSprint then
		local hum=getChar() and getChar():FindFirstChild("Humanoid")
		if hum and hum.WalkSpeed < 17.15 then hum.WalkSpeed=17.15 end
	end

	-- NO FALL DMG
	if S.noFallDmg then
		local hrp=getHRP()
		if hrp then local v=hrp.AssemblyLinearVelocity
			if v.Y<-50 then hrp.AssemblyLinearVelocity=Vector3.new(v.X,-50,v.Z) end
		end
	end

	-- AUTO TRAMPLE
	if S.autoTrample and S.aimbotTarget and S.aimbotTarget.Character then
		local tc=S.aimbotTarget.Character
		local thrp=tc:FindFirstChild("HumanoidRootPart")
		local mhrp=getHRP()
		local mhum=getChar() and getChar():FindFirstChild("Humanoid")
		if thrp and mhrp and mhum then
			local behindPos=thrp.CFrame*CFrame.new(0,0,2)
			mhum:MoveTo(behindPos.Position)
		end
	end

	-- TRIGGERBOT (simple clicker with visibility check)
	if S.trigOn and S.trigKeyActive then
		local n2=tick()
		local delay=S.trigSpeedOn and (S.trigSpeedMs/1000) or 0.05
		if n2-trigLastFire >= delay then
			-- raycast from camera center
			local vp=cam.ViewportSize
			local unitRay=cam:ScreenPointToRay(vp.X/2,vp.Y/2)
			local myC=getChar()
			local params=RaycastParams.new()
			params.FilterDescendantsInstances=myC and {myC} or {}
			params.FilterType=Enum.RaycastFilterType.Exclude
			params.IgnoreWater=true
			local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*1000,params)
			if result then
				local hit=result.Instance
				local char2=hit and hit.Parent
				if char2 and char2:FindFirstChild("Humanoid") then
					local tp2=Players:GetPlayerFromCharacter(char2)
					if tp2 and tp2~=plr and not isInSafeZone(char2) and isPlayerAllowed(tp2) then
						-- reaction delay
						local fireFunc=function()
							pcall(function()
								local vim=game:GetService("VirtualInputManager")
								vim:SendMouseButtonEvent(vp.X/2,vp.Y/2,0,true,game,0)
								task.wait(0.001)
								vim:SendMouseButtonEvent(vp.X/2,vp.Y/2,0,false,game,0)
							end)
						end
						if S.trigReaction and S.trigReactionMs>0 then
							task.delay(S.trigReactionMs/1000,fireFunc)
						else fireFunc() end
						trigLastFire=n2
					end
				end
			end
		end
	end
end)

RS.RenderStepped:Connect(function(dt)
	-- Watermark
	local wm=sg:FindFirstChild("PtichkaWM")
	if wm and S.watermark then
		local wl=wm:FindFirstChild("WML")
		if wl then
			wm.BackgroundColor3=C("hudBg")
			wl.TextColor3=C("hudText")
			local hubC=CT=="white" and "rgb(0,0,0)" or "rgb(255,255,255)"
			wl.Text=string.format(
				'<font color="rgb(60,140,255)">ptichka</font><font color="'..hubC..'">hub</font>  •  %s  •  %d fps  •  %dms  •  %s',
				plr.Name,wm_fps,wm_ping,os.date("%H:%M",os.time()))
		end
	end

	-- AIMBOT
	if S.aimbotOn and S.aimbotKeyActive and S.aimbotTarget then
		if S.aimbotTarget.Character then
			local hum2=S.aimbotTarget.Character:FindFirstChild("Humanoid")
			if hum2 and hum2.Health>0 then
				local bestPos=findBestAimPoint(S.aimbotTarget.Character,S.aimbotPart)
				if bestPos then
					if S.aimbotSmooth>0 then
						local alpha=math.clamp(dt*(21-S.aimbotSmooth)*3,0,1)
						cam.CFrame=cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position,bestPos),alpha)
					else
						cam.CFrame=CFrame.new(cam.CFrame.Position,bestPos)
					end
				else S.aimbotTarget=nil end
			else S.aimbotTarget=nil end
		else S.aimbotTarget=nil end
	end

	-- Dynamic cam
	if S.dynCam and S.aimbotTarget and S.aimbotTarget.Character then
		local part=getBodyPart(S.aimbotTarget.Character,"Head")
		if part then cam.CFrame=cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position,part.Position),0.07) end
	end

	-- FOV circle
	if S.aimbotFOV then
		local r=S.aimbotFOVval
		local vp=cam.ViewportSize
		fovCircle.Size=UDim2.new(0,r*2,0,r*2)
		fovCircle.Position=UDim2.new(0,vp.X/2-r,0,vp.Y/2-r)
		fovStroke.Color=S.aimbotFOVcolor fovCircle.Visible=true
	else fovCircle.Visible=false end

	-- Motion blur
	local blurFx=Lighting:FindFirstChild("PtichkaBlur")
	if blurFx then
		if S.motionBlur then
			local delta=cam.CFrame:ToObjectSpace(lastCamCF)
			local rx,ry,rz=delta:ToEulerAnglesXYZ()
			blurFx.Size=blurFx.Size+(math.clamp(math.sqrt(rx*rx+ry*ry+rz*rz)*90,0,22)-blurFx.Size)*0.25
		else blurFx.Size=0 end
	end
	lastCamCF=cam.CFrame

	auraAngle=auraAngle+dt*55
	local myChar=getChar()

	-- CHINA HAT
	if S.chinaHat and myChar then
		if not myChar:FindFirstChild("ConeHat") then
			local head=myChar:FindFirstChild("Head")
			if head then
				local cone=Instance.new("Part",myChar) cone.Name="ConeHat"
				cone.Size=Vector3.new(1,1,1) cone.Color=S.chinaColor cone.Transparency=0.3
				cone.Anchored=false cone.CanCollide=false
				local mesh=Instance.new("SpecialMesh",cone)
				mesh.MeshType=Enum.MeshType.FileMesh mesh.MeshId="rbxassetid://1033714" mesh.Scale=Vector3.new(1.5,1.1,1.5)
				local weld=Instance.new("Weld",cone) weld.Part0=head weld.Part1=cone weld.C0=CFrame.new(0,0.7,0)
				local hl=Instance.new("Highlight",cone) hl.FillColor=S.chinaHLColor hl.FillTransparency=0.5
				hl.OutlineColor=S.chinaHLColor hl.OutlineTransparency=0
			end
		else
			local cone=myChar.ConeHat cone.Color=S.chinaColor
			local hl=cone:FindFirstChildOfClass("Highlight")
			if hl then hl.FillColor=S.chinaHLColor hl.OutlineColor=S.chinaHLColor end
		end
	end

	-- AURA
	if S.aura and myChar then
		local af=myChar:FindFirstChild("PtichkaAura")
		if not af then createAura(myChar)
		else
			for _,b in ipairs(af:GetDescendants()) do
				if b:IsA("Beam") then b.Color=ColorSequence.new(S.auraColor) end
			end
			local hrp=myChar:FindFirstChild("HumanoidRootPart")
			if hrp then
				local parts={}
				for _,p in ipairs(af:GetChildren()) do if p:IsA("Part") then table.insert(parts,p) end end
				for i,p in ipairs(parts) do
					local weld=p:FindFirstChildOfClass("Weld")
					if weld then
						local ang=((i/#parts)*math.pi*2)+math.rad(auraAngle)
						weld.C0=CFrame.new(math.cos(ang)*2.5,math.sin(ang*2)*2,math.sin(ang)*2.5)
					end
				end
			end
		end
	end

	-- TRAIL
	if S.motionTrail and myChar then
		local hrp=myChar:FindFirstChild("HumanoidRootPart")
		if hrp and not hrp:FindFirstChild("PtichkaTrail") then createTrail(myChar) end
	end

	-- MY CHAMS
	if myChar then
		local myHL=myChar:FindFirstChild("PtichkaMyChams")
		if S.myChams then
			if not myHL then
				local hl=Instance.new("Highlight",myChar) hl.Name="PtichkaMyChams"
				hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
				hl.FillColor=S.myChamsColor hl.OutlineColor=S.myChamsColor
				hl.FillTransparency=S.myChamsAlpha hl.OutlineTransparency=0
			else myHL.FillColor=S.myChamsColor myHL.OutlineColor=S.myChamsColor myHL.FillTransparency=S.myChamsAlpha end
		else if myHL then myHL:Destroy() end end

		-- TOOL CHAMS
		if S.toolChams then
			local myTool=myChar:FindFirstChildOfClass("Tool")
			if myTool then
				for _,p in ipairs(myTool:GetDescendants()) do
					if p:IsA("BasePart") then
						local pid=tostring(p)
						if not S.toolOrigData[pid] then
							local texAlphas={}
							for _,d in ipairs(p:GetChildren()) do
								if d:IsA("Decal") or d:IsA("Texture") then texAlphas[d]=d.Transparency end
							end
							S.toolOrigData[pid]={part=p,mat=p.Material,color=p.Color,texAlphas=texAlphas}
						end
						p.Material=S.toolChamsMat p.Color=S.toolChamsColor
						for _,d in ipairs(p:GetChildren()) do
							if d:IsA("Decal") or d:IsA("Texture") then d.Transparency=1 end
						end
					end
				end
			end
		end
	end

	-- FULLBRIGHT / WORLD COLOR
	if S.worldColor then
		Lighting.Ambient=S.worldColorVal Lighting.ColorShift_Bottom=S.worldColorVal Lighting.ColorShift_Top=S.worldColorVal
	elseif S.fullbright then
		local v=S.fbAmt/100 local col=Color3.fromRGB(255*v,255*v,255*v)
		Lighting.Ambient=col Lighting.ColorShift_Bottom=col Lighting.ColorShift_Top=col
	end

	-- SAFE ZONE ESP
	if S.safeZoneESP and not next(szBoxes) then updateSZesp() end
	if not S.safeZoneESP and next(szBoxes) then for _,b in pairs(szBoxes) do b:Destroy() end szBoxes={} end

	-- BULLET CHAMS
	if S.bulletChams then startBulletChams() else stopBulletChams() end

	-- PLAYER ESP
	for _,p2 in ipairs(Players:GetPlayers()) do
		if p2~=plr and p2.Character then
			local char2=p2.Character
			local hum2=char2:FindFirstChild("Humanoid")
			local head2=char2:FindFirstChild("Head")
			if not hum2 or not head2 then
				cleanESP(p2) removeBoxLines(p2) removeHPBar(p2) continue
			end

			local d=getESP(p2)
			d.namebb.Adornee=head2 d.toolbb.Adornee=head2
			d.ffbb.Adornee=head2 d.szbb.Adornee=head2

			-- Name ESP
			d.namebb.Enabled=S.nameESP
			if S.nameESP then d.nameLabel.Text=p2.Name d.nameLabel.TextColor3=S.nameColor end

			-- Tool ESP
			d.toolbb.Enabled=S.toolESP
			if S.toolESP then
				local t2=char2:FindFirstChildOfClass("Tool")
				d.toolLabel.Text=t2 and t2.Name or "" d.toolLabel.TextColor3=S.toolColor
			end

			-- BOX ESP + HP BAR (screen space, aligned)
			local minX,minY,maxX,maxY=getBBox(p2)
			if S.boxESP and minX then
				local lines=getBoxLines(p2)
				drawBox2D(p2,lines,minX,minY,maxX,maxY)
			else
				if boxLines[p2] then for _,f in ipairs(boxLines[p2]) do f.Visible=false end end
			end

			-- HP bar aligned to box
			if S.healthESP and minX then
				local hpd=getHPBar(p2)
				local boxH=maxY-minY
				local barW=4
				hpd.bg.Position=UDim2.new(0,minX-barW-2,0,minY)
				hpd.bg.Size=UDim2.new(0,barW,0,boxH)
				hpd.bg.Visible=true
				local hp=math.max(0,hum2.Health)
				local mhp=math.max(1,hum2.MaxHealth)
				local ratio=hp/mhp
				hpd.fill.Size=UDim2.new(1,0,ratio,0)
				local r=(1-ratio) local g=ratio
				hpd.fill.BackgroundColor3=Color3.fromRGB(r*255,g*255,30)
				hpd.num.Text=math.floor(hp)
				hpd.num.TextColor3=Color3.fromRGB(r*255,g*255,30)
			else
				if hpBars[p2] then hpBars[p2].bg.Visible=false end
			end

			-- CHAMS
			if S.chams then
				if not d.highlight then
					local hl=Instance.new("Highlight",char2) hl.Name="PtichkaChams"
					hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
					hl.FillColor=S.chamsColor hl.OutlineColor=S.chamsColor
					hl.FillTransparency=S.chamsAlpha hl.OutlineTransparency=0
					d.highlight=hl
					-- anti-highlight on tool
					local tool2=char2:FindFirstChildOfClass("Tool")
					if tool2 then
						local ah=Instance.new("Highlight",tool2) ah.Name="PtichkaAntiHL"
						ah.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
						ah.FillTransparency=1 ah.OutlineTransparency=1
					end
				else
					d.highlight.FillColor=S.chamsColor d.highlight.OutlineColor=S.chamsColor
					d.highlight.FillTransparency=S.chamsAlpha
				end
			else
				if d.highlight then d.highlight:Destroy() d.highlight=nil end
			end

			-- FORCEFIELD INDICATOR
			d.ffbb.Enabled=S.ffIndicator and (char2:FindFirstChildOfClass("ForceField")~=nil)

			-- SAFE ZONE INDICATOR
			d.szbb.Enabled=S.szIndicator and isInSafeZone(char2)

			-- HIT LOGS
			if S.hitlogs then
				local curHP=hum2.Health
				local prev=prevHP[p2]
				if prev and prev>curHP+0.5 then
					addHitLog("Hitting "..p2.Name.." = -"..math.floor(prev-curHP).." hp")
				end
				prevHP[p2]=curHP
			end
		else
			cleanESP(p2) removeBoxLines(p2) removeHPBar(p2) prevHP[p2]=nil
		end
	end

	-- TARGET HUD
	local hud=sg:FindFirstChild("PtichkaHUD")
	if hud and S.targetHUD then
		hud.BackgroundColor3=C("hudBg")
		local dn=hud:FindFirstChild("DisplayName")
		local un=hud:FindFirstChild("Username")
		local hp=hud:FindFirstChild("HP")
		local av=hud:FindFirstChild("Avatar")
		if dn then dn.TextColor3=C("hudText") end
		if un then un.TextColor3=C("hudDim") end
		if S.aimbotTarget and S.aimbotTarget.Character then
			local tgt=S.aimbotTarget
			local hum2=tgt.Character:FindFirstChild("Humanoid")
			if dn then dn.Text=tgt.DisplayName end
			if un then un.Text="@"..tgt.Name end
			if hp and hum2 then
				local h=math.floor(hum2.Health) local mh=math.floor(hum2.MaxHealth)
				hp.Text=h.." / "..mh.." HP"
				local r=h/math.max(mh,1) hp.TextColor3=Color3.fromRGB((1-r)*255,r*255,30)
			end
			if av then
				if av:GetAttribute("lastTarget")~=tgt.UserId then
					av:SetAttribute("lastTarget",tgt.UserId) av.Image=""
					task.spawn(function()
						local ok,img=pcall(function()
							return Players:GetUserThumbnailAsync(tgt.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size100x100)
						end)
						if ok and img and av.Parent then av.Image=img end
					end)
				end
			end
		else
			if dn then dn.Text="No target" end if un then un.Text="" end if hp then hp.Text="" end
			if av then av.Image="" av:SetAttribute("lastTarget",nil) end
		end
	end

	-- WASD
	local wi=sg:FindFirstChild("PtichkaWASD")
	if wi and S.wasdInd then
		local wasdMap={W=Enum.KeyCode.W,A=Enum.KeyCode.A,S=Enum.KeyCode.S,D=Enum.KeyCode.D,SPC=Enum.KeyCode.Space}
		for kn,kc in pairs(wasdMap) do
			local kf=wi:FindFirstChild("K_"..kn)
			if kf then
				local pressed=UIS:IsKeyDown(kc)
				kf.BackgroundColor3=pressed and Color3.fromRGB(60,140,255) or C("hudBg")
				local kl2=kf:FindFirstChildOfClass("TextLabel")
				if kl2 then kl2.TextColor3=pressed and Color3.white or C("hudDim") end
			end
		end
	end

	-- KEYBIND INDICATOR
	local ki=sg:FindFirstChild("PtichkaKB")
	if ki and S.keybindInd then
		local kl=ki:FindFirstChild("KBList")
		if kl then
			kl.TextColor3=C("hudText")
			local lines={}
			if S.aimbotKey then
				local col=S.aimbotKeyActive and 'rgb(60,140,255)' or 'rgb(150,150,160)'
				table.insert(lines,'<font color="'..col..'">Aimbot ['..S.aimbotKey.Name..']</font>')
			end
			if S.trigKey then
				local col=S.trigKeyActive and 'rgb(60,140,255)' or 'rgb(150,150,160)'
				table.insert(lines,'<font color="'..col..'">Trigger ['..S.trigKey.Name..']</font>')
			end
			kl.RichText=true
			kl.Text=#lines>0 and table.concat(lines,"\n") or "—"
			local h=math.max(52,#lines*16+32)
			ki.Size=UDim2.new(0,180,0,h)
		end
	end
end)

-- ============================================================
-- INPUT HANDLER
-- ============================================================
UIS.InputBegan:Connect(function(inp,gpe)
	if gpe or settingKey then return end
	if inp.KeyCode==Enum.KeyCode.Insert then
		if guiOpen then _G.PtichkaCloseGUI() else _G.PtichkaOpenGUI() end
		return
	end

	-- AIMBOT KEY
	if S.aimbotKey and inp.KeyCode==S.aimbotKey and S.aimbotOn then
		if S.aimbotKeyMode=="always on" then return end
		if S.aimbotKeyMode=="toggle" then
			S.aimbotKeyActive=not S.aimbotKeyActive
			if S.aimbotKeyActive then
				S.aimbotTarget=getClosestToCenter()
				if S.aimbotTarget then
					local vp=cam.ViewportSize
					pcall(function() game:GetService("VirtualInputManager"):SendMouseMoveEvent(vp.X/2,vp.Y/2,game) end)
				end
			else S.aimbotTarget=nil end
		else -- hold
			S.aimbotKeyActive=true
			S.aimbotTarget=getClosestToCenter()
			if S.aimbotTarget then
				local vp=cam.ViewportSize
				pcall(function() game:GetService("VirtualInputManager"):SendMouseMoveEvent(vp.X/2,vp.Y/2,game) end)
			end
		end
	end

	-- TRIGGER KEY
	if S.trigKey and inp.KeyCode==S.trigKey and S.trigOn then
		if S.trigKeyMode=="always on" then return end
		if S.trigKeyMode=="toggle" then S.trigKeyActive=not S.trigKeyActive
		else S.trigKeyActive=true end
	end
end)

UIS.InputEnded:Connect(function(inp,gpe)
	if gpe then return end
	if S.aimbotKey and inp.KeyCode==S.aimbotKey and S.aimbotKeyMode=="hold" then
		S.aimbotKeyActive=false S.aimbotTarget=nil
	end
	if S.trigKey and inp.KeyCode==S.trigKey and S.trigKeyMode=="hold" then
		S.trigKeyActive=false
	end
end)

-- Always on watcher
RS.Heartbeat:Connect(function()
	if S.aimbotOn and S.aimbotKeyMode=="always on" then
		S.aimbotKeyActive=true
		if not S.aimbotTarget then S.aimbotTarget=getClosestToCenter() end
	end
	if S.trigOn and S.trigKeyMode=="always on" then S.trigKeyActive=true end
end)

-- ============================================================
-- CHARACTER EVENTS
-- ============================================================
plr.CharacterAdded:Connect(function(char)
	S.aimbotTarget=nil S.aimbotKeyActive=false S.trigKeyActive=false
	NR_HookCharacter(char)
	task.wait(0.5)
	if S.aura then createAura(char) end
	if S.motionTrail then createTrail(char) end
end)

Players.PlayerRemoving:Connect(function(p2)
	cleanESP(p2) removeBoxLines(p2) removeHPBar(p2) prevHP[p2]=nil
	if S.aimbotTarget==p2 then S.aimbotTarget=nil S.aimbotKeyActive=false end
end)

print("[PtichkaHub] loaded | INSERT to toggle")
