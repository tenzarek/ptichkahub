mkToggle(miscTab,"Turn Off Cheat",false,function(v)
	if not v then return end
	S.aimbotOn=false S.aimbotTarget=nil S.trigOn=false S.trigActive=false S.noRecoil=false
	S.boxESP=false S.nameESP=false S.healthESP=false S.chams=false S.gunESP=false
	S.fullbright=false S.worldColor=false S.motionBlur=false S.bulletChams=false
	if S.origLight.Ambient then Lighting.Ambient=S.origLight.Ambient end
	if S.origLight.CSB then Lighting.ColorShift_Bottom=S.origLight.CSB end
	if S.origLight.CST then Lighting.ColorShift_Top=S.origLight.CST end
	local bl=Lighting:FindFirstChild("PtichkaBlur") if bl then bl:Destroy() end
	StopGunESP()
	local c=getChar()
	if c then
		local cone=c:FindFirstChild("ConeHat") if cone then cone:Destroy() end
		local af=c:FindFirstChild("PtichkaAura") if af then af:Destroy() end
	end
	for _,n in ipairs({"PtichkaWM","PtichkaHUD","PtichkaKB","PtichkaWASD"}) do
		local f=sg:FindFirstChild(n) if f then f:Destroy() end
	end
	_G.PtichkaCloseGUI()
end)

-- ============================================================
-- OPEN / CLOSE  (FIXED: proper state management)
-- ============================================================
local guiOpen=false
local guiAnimating=false

function _G.PtichkaOpenGUI()
	if guiAnimating or guiOpen then return end
	guiAnimating=true
	guiOpen=true
	mainFrame.Size=UDim2.new(0,W,0,0)
	mainFrame.Visible=true
	local tw=TS:Create(mainFrame,TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
		{Size=UDim2.new(0,W,0,H)})
	tw:Play()
	tw.Completed:Connect(function() guiAnimating=false end)
end

function _G.PtichkaCloseGUI()
	if guiAnimating or not guiOpen then return end
	guiAnimating=true
	guiOpen=false
	local tw=TS:Create(mainFrame,TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In),
		{Size=UDim2.new(0,W,0,0)})
	tw:Play()
	tw.Completed:Connect(function()
		mainFrame.Visible=false
		guiAnimating=false
	end)
end

UIS.InputBegan:Connect(function(inp,gpe)
	if gpe or settingKey then return end
	if inp.KeyCode==Enum.KeyCode.Insert then
		if guiOpen then _G.PtichkaCloseGUI() else _G.PtichkaOpenGUI() end
	end
end)

-- Drag
do
	local dr,ds,dp=false,nil,nil
	topbar.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=true ds=i.Position dp=mainFrame.Position end
	end)
	topbar.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=false end
	end)
	UIS.InputChanged:Connect(function(i)
		if dr and i.UserInputType==Enum.UserInputType.MouseMovement then
			local d=i.Position-ds
			mainFrame.Position=UDim2.new(dp.X.Scale,dp.X.Offset+d.X,dp.Y.Scale,dp.Y.Offset+d.Y)
		end
	end)
end

-- Close mode popup when clicking elsewhere
UIS.InputBegan:Connect(function(inp,gpe)
	if inp.UserInputType==Enum.UserInputType.MouseButton1 then
		modePopup.Visible=false
	end
end)

