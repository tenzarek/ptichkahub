local tlpCards = {}
local function refreshTargetList()
	for _,c in ipairs(tlpScroll:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end
	tlpCards = {}
	for _,p2 in ipairs(Players:GetPlayers()) do
		if p2==plr then continue end
		local card=Instance.new("Frame",tlpScroll)
		card.Size=UDim2.new(1,-4,0,44) card.BackgroundColor3=S.targetList[p2.Name] and C("hover") or C("card")
		card.BorderSizePixel=0 card.ZIndex=702
		Instance.new("UICorner",card).CornerRadius=UDim.new(0,6)
		local av2=Instance.new("ImageLabel",card) av2.Size=UDim2.new(0,32,0,32)
		av2.Position=UDim2.new(0,6,0.5,-16) av2.BackgroundColor3=C("off")
		av2.BorderSizePixel=0 av2.ZIndex=703
		Instance.new("UICorner",av2).CornerRadius=UDim.new(0,6)
		task.spawn(function()
			local ok,img=pcall(function() return Players:GetUserThumbnailAsync(p2.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size100x100) end)
			if ok and img and av2.Parent then av2.Image=img end
		end)
		local nl=Instance.new("TextLabel",card) nl.Size=UDim2.new(1,-54,0,20)
		nl.Position=UDim2.new(0,44,0,6) nl.BackgroundTransparency=1
		nl.Text=p2.DisplayName nl.TextColor3=C("text") nl.TextSize=13 nl.Font=Enum.Font.GothamBold
		nl.TextXAlignment=Enum.TextXAlignment.Left nl.ZIndex=703
		local ul=Instance.new("TextLabel",card) ul.Size=UDim2.new(1,-54,0,14)
		ul.Position=UDim2.new(0,44,0,26) ul.BackgroundTransparency=1
		ul.Text="@"..p2.Name ul.TextColor3=C("dim") ul.TextSize=10 ul.Font=Enum.Font.Gotham
		ul.TextXAlignment=Enum.TextXAlignment.Left ul.ZIndex=703
		local selDot=Instance.new("Frame",card) selDot.Size=UDim2.new(0,10,0,10)
		selDot.Position=UDim2.new(1,-20,0.5,-5)
		selDot.BackgroundColor3=S.targetList[p2.Name] and Color3.fromRGB(60,200,60) or C("off")
		selDot.BorderSizePixel=0 selDot.ZIndex=703
		Instance.new("UICorner",selDot).CornerRadius=UDim.new(1,0)

		card.InputBegan:Connect(function(inp)
			if inp.UserInputType==Enum.UserInputType.MouseButton1 then
				if S.targetList[p2.Name] then
					S.targetList[p2.Name]=nil
					TS:Create(card,TweenInfo.new(0.15),{BackgroundColor3=C("card")}):Play()
					selDot.BackgroundColor3=C("off")
				else
					S.targetList[p2.Name]=true
					TS:Create(card,TweenInfo.new(0.15),{BackgroundColor3=C("hover")}):Play()
					selDot.BackgroundColor3=Color3.fromRGB(60,200,60)
				end
			end
		end)
		tlpCards[p2]=card
	end
end

