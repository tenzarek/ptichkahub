local _ord=0
local function no() _ord=_ord+1 return _ord end
local settingKey=false

local function mkSection(p,t)
	local f=Instance.new("Frame",p) f.Size=UDim2.new(1,0,0,22)
	f.BackgroundTransparency=1 f.LayoutOrder=no()
	local l=Instance.new("TextLabel",f) l.Size=UDim2.new(1,0,1,0)
	l.BackgroundTransparency=1 l.Text=string.upper(t)
	l.TextColor3=Color3.fromRGB(60,140,255) l.TextSize=10 l.Font=Enum.Font.GothamBold
	l.TextXAlignment=Enum.TextXAlignment.Left
end

-- Mode menu popup (high ZIndex, parent to sg so it's above everything)
local modePopup=Instance.new("Frame",sg)
modePopup.Name="ModePopup" modePopup.Size=UDim2.new(0,100,0,90)
modePopup.BackgroundColor3=C("card") modePopup.BorderSizePixel=0
modePopup.Visible=false modePopup.ZIndex=2000
Instance.new("UICorner",modePopup).CornerRadius=UDim.new(0,6)
local mpStr=Instance.new("UIStroke",modePopup) mpStr.Color=C("border") mpStr.Thickness=1
onTC(function() modePopup.BackgroundColor3=C("card") mpStr.Color=C("border") end)

local modeNames={"hold","toggle","always on"}
local modeCallbacks={}
for i,mn in ipairs(modeNames) do
	local mb=Instance.new("TextButton",modePopup)
	mb.Size=UDim2.new(1,-8,0,26) mb.Position=UDim2.new(0,4,0,4+(i-1)*28)
	mb.BackgroundTransparency=1 mb.Text=mn mb.TextColor3=C("dim")
	mb.TextSize=11 mb.Font=Enum.Font.Gotham mb.ZIndex=2001
	onTC(function() mb.TextColor3=C("dim") end)
	mb.MouseEnter:Connect(function() mb.TextColor3=C("text") end)
	mb.MouseLeave:Connect(function() mb.TextColor3=C("dim") end)
	mb.MouseButton1Click:Connect(function()
		modePopup.Visible=false
		if modePopup:GetAttribute("currentCB") then
			local cb=modeCallbacks[modePopup:GetAttribute("currentCB")]
			if cb then cb(mn) end
		end
	end)
end

local function mkKeybind(parent,label,onKey,onMode)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,36) row.BackgroundColor3=C("card")
	row.BorderSizePixel=0 row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	local lbl=Instance.new("TextLabel",row) lbl.Size=UDim2.new(0.55,0,1,0)
	lbl.Position=UDim2.new(0,12,0,0) lbl.BackgroundTransparency=1
	lbl.Text=label lbl.TextColor3=C("text") lbl.TextSize=12 lbl.Font=Enum.Font.Gotham
	lbl.TextXAlignment=Enum.TextXAlignment.Left
	onTC(function() row.BackgroundColor3=C("card") lbl.TextColor3=C("text") end)

	local kbBtn=Instance.new("TextButton",row)
	kbBtn.Size=UDim2.new(0,80,0,22) kbBtn.Position=UDim2.new(1,-88,0.5,-11)
	kbBtn.BackgroundColor3=C("off") kbBtn.BorderSizePixel=0
	kbBtn.Text="none" kbBtn.TextColor3=Color3.fromRGB(60,140,255)
	kbBtn.TextSize=11 kbBtn.Font=Enum.Font.GothamMedium kbBtn.ZIndex=2
	Instance.new("UICorner",kbBtn).CornerRadius=UDim.new(0,4)
	onTC(function() kbBtn.BackgroundColor3=C("off") end)

	-- assign unique id for mode callback
	local cbId=tostring(math.random(100000,999999))
	if onMode then modeCallbacks[cbId]=onMode end

	kbBtn.MouseButton2Click:Connect(function()
		local ap=kbBtn.AbsolutePosition
		modePopup.Position=UDim2.new(0,ap.X-10,0,ap.Y+26)
		modePopup:SetAttribute("currentCB",cbId)
		modePopup.Visible=not modePopup.Visible
	end)

	local boundKey=nil
	kbBtn.MouseButton1Click:Connect(function()
		if settingKey then return end
		settingKey=true kbBtn.Text="..."
		local cn cn=UIS.InputBegan:Connect(function(inp2,gpe)
			if gpe then return end
			cn:Disconnect() settingKey=false
			if inp2.KeyCode==Enum.KeyCode.Escape then
				kbBtn.Text="none" boundKey=nil if onKey then onKey(nil) end
			else
				kbBtn.Text=inp2.KeyCode.Name boundKey=inp2.KeyCode if onKey then onKey(inp2.KeyCode) end
			end
		end)
	end)
	return row, function() return boundKey end
end

local function mkToggle(parent,label,default,callback)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,36) row.BackgroundColor3=C("card")
	row.BorderSizePixel=0 row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	local lbl=Instance.new("TextLabel",row) lbl.Size=UDim2.new(1,-52,1,0)
	lbl.Position=UDim2.new(0,12,0,0) lbl.BackgroundTransparency=1
	lbl.Text=label lbl.TextColor3=C("text") lbl.TextSize=12 lbl.Font=Enum.Font.Gotham
	lbl.TextXAlignment=Enum.TextXAlignment.Left
	local sw=Instance.new("TextButton",row) sw.Size=UDim2.new(0,36,0,18)
	sw.Position=UDim2.new(1,-46,0.5,-9) sw.BackgroundColor3=default and C("on") or C("off")
	sw.BorderSizePixel=0 sw.Text="" sw.ZIndex=2
	Instance.new("UICorner",sw).CornerRadius=UDim.new(1,0)
	local dot=Instance.new("Frame",sw) dot.Size=UDim2.new(0,12,0,12)
	dot.Position=default and UDim2.new(1,-14,0.5,-6) or UDim2.new(0,2,0.5,-6)
	dot.BackgroundColor3=default and Color3.new(1,1,1) or C("dot")
	dot.BorderSizePixel=0 dot.ZIndex=3
	Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)
	local state=default or false
	onTC(function()
		row.BackgroundColor3=C("card") lbl.TextColor3=C("text")
		sw.BackgroundColor3=state and C("on") or C("off")
		dot.BackgroundColor3=state and Color3.new(1,1,1) or C("dot")
	end)
	local function toggle()
		state=not state
		TS:Create(sw,TweenInfo.new(0.15),{BackgroundColor3=state and C("on") or C("off")}):Play()
		TS:Create(dot,TweenInfo.new(0.2,Enum.EasingStyle.Back),{
			Position=state and UDim2.new(1,-14,0.5,-6) or UDim2.new(0,2,0.5,-6),
			BackgroundColor3=state and Color3.new(1,1,1) or C("dot"),
		}):Play()
		callback(state)
	end
	sw.MouseButton1Click:Connect(toggle)
	row.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseMovement then
			TS:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C("hover")}):Play()
		end
	end)
	row.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseMovement then
			TS:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C("card")}):Play()
		end
	end)
	return row, function() return state end
end

local function mkSlider(parent,label,min,max,def,step,cb)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,54) row.BackgroundColor3=C("card")
	row.BorderSizePixel=0 row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	local lbl=Instance.new("TextLabel",row) lbl.Size=UDim2.new(0.6,0,0,22)
	lbl.Position=UDim2.new(0,12,0,4) lbl.BackgroundTransparency=1
	lbl.Text=label lbl.TextColor3=C("text") lbl.TextSize=12 lbl.Font=Enum.Font.Gotham
	lbl.TextXAlignment=Enum.TextXAlignment.Left
	local valL=Instance.new("TextLabel",row) valL.Size=UDim2.new(0,60,0,22)
	valL.Position=UDim2.new(1,-70,0,4) valL.BackgroundTransparency=1
	valL.Text=tostring(def) valL.TextColor3=Color3.fromRGB(60,140,255)
	valL.TextSize=12 valL.Font=Enum.Font.GothamMedium valL.TextXAlignment=Enum.TextXAlignment.Right
	local track=Instance.new("Frame",row) track.Size=UDim2.new(1,-24,0,5)
	track.Position=UDim2.new(0,12,0,38) track.BackgroundColor3=C("off") track.BorderSizePixel=0
	Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
	local fill=Instance.new("Frame",track)
	fill.Size=UDim2.new(math.clamp((def-min)/(max-min),0,1),0,1,0)
	fill.BackgroundColor3=Color3.fromRGB(60,140,255) fill.BorderSizePixel=0
	Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
	local knob=Instance.new("Frame",track) knob.Size=UDim2.new(0,13,0,13)
	knob.Position=UDim2.new(math.clamp((def-min)/(max-min),0,1),-6,0.5,-6)
	knob.BackgroundColor3=Color3.new(1,1,1) knob.BorderSizePixel=0 knob.ZIndex=3
	Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
	onTC(function() row.BackgroundColor3=C("card") lbl.TextColor3=C("text") track.BackgroundColor3=C("off") end)
	local dr=false
	local function upd(x)
		local r=math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
		local v=math.clamp(math.floor((min+(max-min)*r)/step+0.5)*step,min,max)
		local f=(v-min)/(max-min)
		fill.Size=UDim2.new(f,0,1,0) knob.Position=UDim2.new(f,-6,0.5,-6)
		valL.Text=tostring(v) cb(v)
	end
	track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=true upd(i.Position.X) end end)
	knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=true end end)
	UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=false end end)
	UIS.InputChanged:Connect(function(i) if dr and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
end

local function mkRGB(parent,label,default,cb)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,36) row.BackgroundColor3=C("card")
	row.BorderSizePixel=0 row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	local lbl=Instance.new("TextLabel",row) lbl.Size=UDim2.new(0.45,0,1,0)
	lbl.Position=UDim2.new(0,12,0,0) lbl.BackgroundTransparency=1
	lbl.Text=label lbl.TextColor3=C("text") lbl.TextSize=12 lbl.Font=Enum.Font.Gotham
	lbl.TextXAlignment=Enum.TextXAlignment.Left
	local prev=Instance.new("Frame",row) prev.Size=UDim2.new(0,16,0,16)
	prev.Position=UDim2.new(1,-150,0.5,-8) prev.BackgroundColor3=default prev.BorderSizePixel=0
	Instance.new("UICorner",prev).CornerRadius=UDim.new(1,0)
	local inp=Instance.new("TextBox",row) inp.Size=UDim2.new(0,118,0,24)
	inp.Position=UDim2.new(1,-126,0.5,-12) inp.BackgroundColor3=C("off") inp.BorderSizePixel=0
	local dr2,dg2,db2=math.floor(default.R*255),math.floor(default.G*255),math.floor(default.B*255)
	inp.Text=dr2..", "..dg2..", "..db2 inp.TextColor3=C("text")
	inp.TextSize=11 inp.Font=Enum.Font.Gotham inp.PlaceholderText="R, G, B" inp.ZIndex=2
	Instance.new("UICorner",inp).CornerRadius=UDim.new(0,4)
	onTC(function() row.BackgroundColor3=C("card") lbl.TextColor3=C("text") inp.BackgroundColor3=C("off") inp.TextColor3=C("text") end)
	inp.FocusLost:Connect(function()
		local r,g,b=inp.Text:match("(%d+)%s*,%s*(%d+)%s*,%s*(%d+)")
		if r then local col=Color3.fromRGB(tonumber(r),tonumber(g),tonumber(b)) prev.BackgroundColor3=col cb(col) end
	end)
end

local function mkDropdown(parent,label,options,default,cb)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,36) row.BackgroundColor3=C("card")
	row.BorderSizePixel=0 row.ClipsDescendants=true row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	local lbl=Instance.new("TextLabel",row) lbl.Size=UDim2.new(0.45,0,0,36)
	lbl.Position=UDim2.new(0,12,0,0) lbl.BackgroundTransparency=1
	lbl.Text=label lbl.TextColor3=C("text") lbl.TextSize=12 lbl.Font=Enum.Font.Gotham
	lbl.TextXAlignment=Enum.TextXAlignment.Left
	local sel=Instance.new("TextButton",row) sel.Size=UDim2.new(0,130,0,24)
	sel.Position=UDim2.new(1,-142,0,6) sel.BackgroundColor3=C("off") sel.BorderSizePixel=0
	sel.Text=(default or options[1]).."  ▾" sel.TextColor3=C("text")
	sel.TextSize=11 sel.Font=Enum.Font.GothamMedium sel.ZIndex=4
	Instance.new("UICorner",sel).CornerRadius=UDim.new(0,4)
	onTC(function() row.BackgroundColor3=C("card") lbl.TextColor3=C("text") sel.BackgroundColor3=C("off") sel.TextColor3=C("text") end)
	local expanded=false local obs={}
	for i,opt in ipairs(options) do
		local ob=Instance.new("TextButton",row) ob.Size=UDim2.new(0,130,0,26)
		ob.Position=UDim2.new(1,-142,0,4+i*28) ob.BackgroundColor3=Color3.fromRGB(18,18,18)
		ob.BorderSizePixel=0 ob.Text=opt ob.TextColor3=C("dim")
		ob.TextSize=11 ob.Font=Enum.Font.Gotham ob.Visible=false ob.ZIndex=5
		Instance.new("UICorner",ob).CornerRadius=UDim.new(0,4)
		ob.MouseEnter:Connect(function() ob.TextColor3=C("text") end)
		ob.MouseLeave:Connect(function() ob.TextColor3=C("dim") end)
		ob.MouseButton1Click:Connect(function()
			sel.Text=opt.."  ▾" expanded=false
			TS:Create(row,TweenInfo.new(0.15),{Size=UDim2.new(1,0,0,36)}):Play()
			for _,x in ipairs(obs) do x.Visible=false end cb(opt)
		end)
		obs[i]=ob
	end
	sel.MouseButton1Click:Connect(function()
		expanded=not expanded
		if expanded then
			TS:Create(row,TweenInfo.new(0.2,Enum.EasingStyle.Quart),{Size=UDim2.new(1,0,0,38+#options*28)}):Play()
			for _,x in ipairs(obs) do x.Visible=true end
		else
			TS:Create(row,TweenInfo.new(0.15),{Size=UDim2.new(1,0,0,36)}):Play()
			for _,x in ipairs(obs) do x.Visible=false end
		end
	end)
end

local function mkButton(parent,label,cb)
	local row=Instance.new("TextButton",parent)
	row.Size=UDim2.new(1,0,0,36) row.BackgroundColor3=Color3.fromRGB(40,80,140)
	row.BorderSizePixel=0 row.Text=label row.TextColor3=Color3.new(1,1,1)
	row.TextSize=12 row.Font=Enum.Font.GothamMedium row.LayoutOrder=no()
	Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
	row.MouseButton1Click:Connect(cb)
	return row
end

