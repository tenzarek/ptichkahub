local tabs={"main","visuals","misc"}
local tabBtns={} local tabFrames={}

local function mkTabBtn(name)
	local btn=Instance.new("TextButton",tabRow)
	btn.Size=UDim2.new(0,W/3,1,0) btn.BackgroundTransparency=1
	btn.Text=name btn.TextColor3=C("dim") btn.TextSize=13 btn.Font=Enum.Font.GothamMedium
	btn.BorderSizePixel=0 btn.ZIndex=102
	local ul=Instance.new("Frame",btn) ul.Size=UDim2.new(0,0,0,2)
	ul.Position=UDim2.new(0.5,0,1,-2) ul.AnchorPoint=Vector2.new(0.5,0)
	ul.BackgroundColor3=Color3.fromRGB(60,140,255) ul.BorderSizePixel=0 ul.ZIndex=103
	tabBtns[name]={btn=btn,ul=ul}
	onTC(function() btn.TextColor3=C("dim") end)

	local scroll=Instance.new("ScrollingFrame",contentArea)
	scroll.Size=UDim2.new(1,0,1,0) scroll.BackgroundTransparency=1 scroll.BorderSizePixel=0
	scroll.ScrollBarThickness=4 scroll.ScrollBarImageColor3=Color3.fromRGB(60,140,255)
	scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y scroll.CanvasSize=UDim2.new(0,0,0,0)
	scroll.Visible=false scroll.ZIndex=100
	local pad=Instance.new("UIPadding",scroll)
	pad.PaddingLeft=UDim.new(0,14) pad.PaddingRight=UDim.new(0,14)
	pad.PaddingTop=UDim.new(0,10) pad.PaddingBottom=UDim.new(0,10)
	Instance.new("UIListLayout",scroll).Padding=UDim.new(0,6)
	tabFrames[name]=scroll
end

local function switchTab(name)
	for _,n in ipairs(tabs) do
		local d=tabBtns[n] local active=n==name
		d.btn.TextColor3=active and C("text") or C("dim")
		TS:Create(d.ul,TweenInfo.new(0.2,Enum.EasingStyle.Quart),{
			Size=UDim2.new(active and 0.6 or 0,0,0,2)
		}):Play()
		tabFrames[n].Visible=active
	end
end

for _,n in ipairs(tabs) do
	mkTabBtn(n)
	tabBtns[n].btn.MouseButton1Click:Connect(function() switchTab(n) end)
end
switchTab("main")

